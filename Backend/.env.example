# Chronos backend environment variables.
# Copy this file to `.env` and adjust as needed. All variables are prefixed with CHRONOS_.

# --- Application ---
CHRONOS_PROJECT_NAME=Chronos
CHRONOS_VERSION=0.1.0
CHRONOS_DEBUG=false

# --- Server ---
CHRONOS_HOST=0.0.0.0
CHRONOS_PORT=8000

# --- Database (SQLite) ---
CHRONOS_DATABASE_URL=sqlite:///./chronos.db

# --- CORS (comma-separated origins) ---
CHRONOS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- AI providers: Gemini (optional; not integrated yet) ---
# Leave GEMINI_API_KEY blank to run without Gemini — the app still starts.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
